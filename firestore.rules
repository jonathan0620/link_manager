rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      // Allow anyone to check if username exists (for signup)
      allow read: if true;

      // Allow users to create their own document during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Allow users to update their own document
      allow update: if isOwner(userId);

      // Prevent deletion of user documents
      allow delete: if false;
    }

    // Links collection
    match /links/{linkId} {
      // Allow users to read their own links
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Allow users to create links with their userId
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.url is string
        && request.resource.data.url.size() > 0;

      // Allow users to update their own links
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      // Allow users to delete their own links
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Categories collection
    match /categories/{categoryId} {
      // Allow users to read their own categories
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Allow users to create categories with their userId
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      // Allow users to update their own categories
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      // Allow users to delete their own categories
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Verification codes collection
    // Only Cloud Functions can read/write this collection
    match /verification_codes/{email} {
      allow read, write: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
